                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"vendor@eventrental.com\",\n  \"password\": \"SecurePass@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('access_token', res.data.accessToken);",
                  "  pm.test('Token refreshed', () => pm.expect(res.data.accessToken).to.not.be.empty);",
                  "}"
                ],
                "type": "text/javascript"
              }
