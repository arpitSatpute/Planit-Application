  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('access_token',  res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  pm.collectionVariables.set('user_id',       res.data.userId);",
                  "  pm.test('Registration successful', () => pm.expect(res.success).to.be.true);",
                  "  pm.test('Access token present',   () => pm.expect(res.data.accessToken).to.not.be.empty);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@eventrental.com\",\n  \"phone\": \"+919876543210\",\n  \"password\": \"SecurePass@123\",\n  \"role\": \"USER\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register Vendor User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('vendor_access_token', res.data.accessToken);",
                  "  pm.collectionVariables.set('vendor_user_id',      res.data.userId);",
                  "  pm.test('Vendor registration successful', () => pm.expect(res.success).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendor@eventrental.com\",\n  \"phone\": \"+919876543211\",\n  \"password\": \"SecurePass@123\",\n  \"role\": \"VENDOR\",\n  \"firstName\": \"Vendor\",\n  \"lastName\": \"Owner\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('access_token',  res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  pm.collectionVariables.set('user_id',       res.data.userId);",
                  "  pm.test('Login successful', () => pm.expect(res.success).to.be.true);",
                  "  pm.test('Role is USER',     () => pm.expect(res.data.user.role).to.eql('USER'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"testuser@eventrental.com\",\n  \"password\": \"SecurePass@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Vendor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
