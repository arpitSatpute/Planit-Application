    "_postman_id": "planit-platform-v1"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8080/api/v1",  "type": "string" },
    { "key": "access_token",  "value": "",  "type": "string" },
    { "key": "refresh_token", "value": "",  "type": "string" },
    { "key": "user_id",       "value": "",  "type": "string" },
    { "key": "vendor_id",     "value": "",  "type": "string" },
    { "key": "product_id",    "value": "",  "type": "string" },
    { "key": "booking_id",    "value": "",  "type": "string" },
    { "key": "payment_id",    "value": "",  "type": "string" },
    { "key": "review_id",     "value": "",  "type": "string" },
    { "key": "otp_id",        "value": "",  "type": "string" },
    { "key": "conversation_id","value": "conv-001", "type": "string" }
